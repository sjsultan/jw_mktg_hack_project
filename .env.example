# LiteLLM proxy (JW standard — already in your shell as ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN)
# Map them here or just export before running: LITELLM_BASE_URL=$ANTHROPIC_BASE_URL LITELLM_API_KEY=$ANTHROPIC_AUTH_TOKEN
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Fallback: direct Anthropic key (if not using JW proxy)
ANTHROPIC_API_KEY=

# Slack is posted via MCP plugin in Claude Code — no env var needed
